# STEP 1: LOAD YOUR DATASET
# We need to upload movies.csv and credits.csv so Python can read them.
# IN GOOGLE COLAB,DO NOT NEED TO LOAD DIRECTLY WE CAN PROCEED TO IMPORT THE LIBRARIES.


# STEP 2: IMPORT REQUIRED PYTHON LIBRARIES
# These libraries handle data processing, NLP, vectorization, and similarity calculation.

import numpy as np
import pandas as pd
import ast
import nltk
nltk.download('punkt')
from nltk.stem.porter import PorterStemmer
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.metrics.pairwise import cosine_similarity

# STEP 3: READ THE CSV FILES INTO DATAFRAMES
# Loading the dataset helps us clean and process it further.

movies_df  = pd.read_csv('/content/movies.csv')
credits_df = pd.read_csv('/content/credits.csv')

# STEP 4: MERGE BOTH DATAFRAMES INTO A SINGLE DATASET
# Movie details and credits are separate; merging gives us full information for each movie.

movies_df = movies_df.merge(credits_df, on='title')
movies_df = movies_df[['movie_id','title','overview','genres','keywords','cast','crew']]
movies_df.dropna(inplace=True)

# STEP 5: PARSE STRING COLUMNS INTO PYTHON LISTS
# Genres, keywords, cast, and crew are stored as stringified lists and must be converted properly.

def parse_names(text):
    try:
        return [d['name'] for d in ast.literal_eval(text)]
    except:
        return []

def take_top_cast(text, top_n=3):
    try:
        return [d['name'] for d in ast.literal_eval(text)[:top_n]]
    except:
        return []

def fetch_director(text):
    try:
        return [d['name'] for d in ast.literal_eval(text) if d.get('job') == 'Director']
    except:
        return []

# STEP 6: EXTRACT IMPORTANT FEATURES FROM PARSED DATA
# Only key information (genres, keywords, top cast, and director) improves recommendation accuracy.

movies_df['genres']   = movies_df['genres'].apply(parse_names)
movies_df['keywords'] = movies_df['keywords'].apply(parse_names)
movies_df['cast']     = movies_df['cast'].apply(take_top_cast)
movies_df['crew']     = movies_df['crew'].apply(fetch_director)


# STEP 7: CLEAN AND NORMALIZE TEXT DATA
# Removing spaces, cleaning text, and tokenizing ensures consistent processing.

def clean_list(lst):
    return [item.replace(" ", "") for item in lst]

movies_df['genres']   = movies_df['genres'].apply(clean_list)
movies_df['keywords'] = movies_df['keywords'].apply(clean_list)
movies_df['cast']     = movies_df['cast'].apply(clean_list)
movies_df['crew']     = movies_df['crew'].apply(clean_list)

movies_df['overview'] = movies_df['overview'].apply(lambda x: x.split())

# STEP 8: CREATE A SINGLE COMBINED "TAGS" COLUMN
# Combining all important text fields creates a single representation for each movie.

movies_df['tags'] = (
    movies_df['overview']
    + movies_df['genres']
    + movies_df['keywords']
    + movies_df['cast']
    + movies_df['crew']
)

new_df = movies_df[['movie_id','title','tags']].copy()
new_df['tags'] = new_df['tags'].apply(lambda x: " ".join(x).lower())

# STEP 9: APPLY STEMMING & CONVERT TEXT TO NUMERICAL VECTORS
# Stemming reduces similar words to root form, and CountVectorizer converts text into numeric feature vectors.


ps = PorterStemmer()
def stem_text(text):
    return " ".join(ps.stem(word) for word in text.split())

new_df['tags'] = new_df['tags'].apply(stem_text)

cv = CountVectorizer(max_features=5000, stop_words='english')
vectors = cv.fit_transform(new_df['tags']).toarray()

similarity = cosine_similarity(vectors)

# STEP 10: BUILD THE RECOMMENDATION FUNCTION
# Using cosine similarity scores, we find and return the top similar movies.

def recommend(movie_title, top_n=5):
    movie_title = movie_title.lower()

    matches = new_df[new_df['title'].str.lower() == movie_title]
    if matches.empty:
        contains = new_df[new_df['title'].str.lower().str.contains(movie_title)]
        if not contains.empty:
            idx = contains.index[0]
        else:
            print(f"Movie '{movie_title}' not found.")
            return
    else:
        idx = matches.index[0]

    distances = list(enumerate(similarity[idx]))
    distances = sorted(distances, key=lambda x: x[1], reverse=True)

    print(f"Top {top_n} recommendations for '{new_df.iloc[idx].title}':")
    for j, score in distances[1:top_n+1]:
        print(new_df.iloc[j].title, " (similarity:", round(score, 4), ")")
# To get the output call this recommend function :
# recommend("Avatar")
# recommend("Iron Man")
recommend('Avatar')
recommend('Iron Man')
